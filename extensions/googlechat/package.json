{
  "name": "@klawty/googlechat",
  "version": "1.0.0",
  "private": true,
  "description": "Klawty Google Chat channel plugin",
  "type": "module",
  "dependencies": {
    "google-auth-library": "^10.6.2"
  },
  "peerDependencies": {
    "klawty": "workspace:*"
  },
  "peerDependenciesMeta": {
    "klawty": {
      "optional": true
    }
  },
  "klawty": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "googlechat",
      "label": "Google Chat",
      "selectionLabel": "Google Chat (Chat API)",
      "detailLabel": "Google Chat",
      "docsPath": "/channels/googlechat",
      "docsLabel": "googlechat",
      "blurb": "Google Workspace Chat app via HTTP webhooks.",
      "aliases": [
        "gchat",
        "google-chat"
      ],
      "order": 55
    },
    "install": {
      "npmSpec": "@klawty/googlechat",
      "localPath": "extensions/googlechat",
      "defaultChoice": "npm"
    }
  }
}

{
  "name": "@klawty/zalo",
  "version": "1.0.0",
  "description": "Klawty Zalo channel plugin",
  "type": "module",
  "dependencies": {
    "undici": "7.24.4",
    "zod": "^4.3.6"
  },
  "klawty": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "zalo",
      "label": "Zalo",
      "selectionLabel": "Zalo (Bot API)",
      "docsPath": "/channels/zalo",
      "docsLabel": "zalo",
      "blurb": "Vietnam-focused messaging platform with Bot API.",
      "aliases": [
        "zl"
      ],
      "order": 80,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@klawty/zalo",
      "localPath": "extensions/zalo",
      "defaultChoice": "npm"
    },
    "release": {
      "publishToNpm": true
    }
  }
}

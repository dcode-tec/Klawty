# Klawty — Environment Variables
# Copy to .env and fill in your values: cp .env.example .env

# ─── LLM API (required) ─────────────────────────────────────────
# OpenRouter: one key for 200+ models (Claude, GPT-4, Gemini, etc.)
OPENROUTER_API_KEY=sk-or-v1-...

# ─── Vector Memory (optional — requires Docker) ──────────────────
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=           # only needed for Qdrant Cloud

# ─── Channels (optional) ─────────────────────────────────────────
# DISCORD_BOT_TOKEN=
# SLACK_BOT_TOKEN=
# TELEGRAM_BOT_TOKEN=

# ─── License (optional — for premium features) ──────────────────
# LICENSE_KEY=

# ─── Runtime ──────────────────────────────────────────────────────
LOG_LEVEL=info
# DAILY_COST_CAP_USD=5
